{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "reminder-*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:tray:default",
    "core:image:default",
    "dialog:allow-open",
    "opener:default",
    "sql:default",
    "sql:allow-execute"
  ]
}
